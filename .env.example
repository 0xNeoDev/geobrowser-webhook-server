# HTTP port (default 3000)
PORT=3000

# Postgres connection string for the app server's own database
DATABASE_URL=postgres://user:pass@localhost:5432/geobrowser_notifications

# Max Postgres pool connections (default 10)
DB_POOL_MAX=10

# Shared secret for verifying the X-Geo-Signature HMAC on inbound webhooks.
# Must match the `secret` of this app's row in Gaia's `app_webhooks` table.
# Generate with: openssl rand -hex 32
GEO_WEBHOOK_SECRET=your-secret-here

# Privy server-side auth (verifies the front-end's access token, resolves email)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Email channel kill-switch. Default true; set EMAIL_ENABLED=false to stop ALL
# outbound email (notifications still land in-app) without removing credentials.
EMAIL_ENABLED=true

# Email delivery (MailerSend). Optional — if unset, the email channel is
# disabled and notifications still land in-app.
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=notifications@geobrowser.io
MAILERSEND_FROM_NAME=Geo

# Per-recipient email cap over a rolling hour. 0 = unlimited (off).
EMAIL_MAX_PER_RECIPIENT_PER_HOUR=0

# Staleness gate: skip email for events whose on-chain timestamp is older than
# this many days (recovery safety after an outage/backlog). 0 = no gate.
STALE_THRESHOLD_DAYS=5

# Email outbox worker (async delivery, decoupled from the webhook ack).
EMAIL_WORKER_POLL_MS=2000   # how often to poll for pending email
EMAIL_CLAIM_BATCH=20        # rows claimed per poll
EMAIL_MAX_ATTEMPTS=6        # send attempts (backoff) before email_status=failed
EMAIL_LEASE_SECONDS=120     # claim lease; reclaimed if a worker dies mid-send
