# Local demo config — copy to scripts/demo.env (gitignored) and fill in.
# Sourced by scripts/seed-demo.sh and exported when running the seeds.

# --- Identities captured from the Geo Browser UI (testnet) ---------------------
# DEMO_SPACE_ID must be a Public/DAO space WITH GOVERNANCE that you edit — NOT a
# personal space (personal spaces have no governance, so no proposal can be made
# and no PROPOSAL_CREATED event ever fires). Create a Public space if unsure.
DEMO_SPACE_ID=
# Your personal space id = getSpaceByAddress(<your smart-account address>).
# This is the notification recipient (seeded as an editor of DEMO_SPACE_ID).
DEMO_USER_SPACE_ID=
DEMO_EMAIL=neo@wonderland.xyz
DEMO_PRIVY_USER_ID=demo-neo

# --- gaia Postgres (from `docker compose --profile infra up -d`) ---------------
GAIA_DB_URL=postgresql://postgres:postgres@localhost:5432/gaia

# --- webhook server app-db + secret -------------------------------------------
# DATABASE_URL is the webhook server's OWN db (not gaia's). The secret MUST equal
# the app_webhooks.secret row, or the HMAC X-Geo-Signature check rejects the POST.
DATABASE_URL=postgres://test:test@127.0.0.1:5433/notifications_test
GEO_WEBHOOK_SECRET=demo-secret-change-me
WEBHOOK_URL=http://localhost:3001/webhooks/geo

# --- config.ts requires these on import (unused on the webhook ingest path) ---
PRIVY_APP_ID=x
PRIVY_APP_SECRET=x
